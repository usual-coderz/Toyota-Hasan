<script>
setTimeout(function(){document.body.classList.add('loaded');},1900);
function openModal(card){
var modal=document.getElementById("videoModal");
var video=document.getElementById("modalVideo");
var source=card.querySelector("source").src;
var title=card.querySelector("h3").textContent;
video.src=source;
video.load();
video.play().catch(function(){});
document.getElementById("modalTitle").textContent=title;
modal.classList.add("active");
document.body.style.overflow="hidden";
}
function closeModal(){
var modal=document.getElementById("videoModal");
var video=document.getElementById("modalVideo");
video.pause();
video.src="";
modal.classList.remove("active");
document.body.style.overflow="auto";
}
document.getElementById("videoModal").addEventListener("click",function(e){
if(e.target===this)closeModal();
});
document.addEventListener("keydown",function(e){
if(e.key==="Escape")closeModal();
});
var cards=document.querySelectorAll(".video-card");
cards.forEach(function(c){
var v=c.querySelector("video");
if(v){
c.addEventListener("mouseenter",function(){v.play().catch(function(){})});
c.addEventListener("mouseleave",function(){v.pause();v.currentTime=0;});
}
});
function buy(){window.open("https://t.me/sexiest_soul","_blank");}
function openVoiceModal(){
var vm=document.getElementById("voiceModal");
var va=document.getElementById("voiceAudio");
vm.classList.add("active");
va.load();
va.play().catch(function(){});
document.body.style.overflow="hidden";
var btn=document.getElementById("demoVoiceBtn");
btn.classList.add("playing");
btn.innerHTML='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg> Playing';
}
function closeVoiceModal(){
var vm=document.getElementById("voiceModal");
var va=document.getElementById("voiceAudio");
va.pause();
va.currentTime=0;
vm.classList.remove("active");
document.body.style.overflow="auto";
var btn=document.getElementById("demoVoiceBtn");
btn.classList.remove("playing");
btn.innerHTML='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg> Mummy Voice';
}
document.getElementById("voiceModal").addEventListener("click",function(e){
if(e.target===this)closeVoiceModal();
});
</script>
