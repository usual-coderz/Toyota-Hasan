<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mummy Premium Feels</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Inter',sans-serif;background:#0a0a0a;color:#ccc;overflow-x:hidden;}
.loader-wrap{position:fixed;top:0;left:0;width:100%;height:100%;background:#0a0a0a;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:9999;transition:opacity 0.6s ease;}
.loader-wrap.hide{opacity:0;pointer-events:none;}
.loader-logo{font-size:32px;font-weight:700;color:#fff;letter-spacing:6px;margin-bottom:20px;}
.loader-logo span{color:#888;}
.loader-bar{width:200px;height:3px;background:#222;border-radius:4px;overflow:hidden;}
.loader-bar-inner{width:0%;height:100%;background:#fff;border-radius:4px;animation:loadBar 1.8s ease forwards;}
@keyframes loadBar{0%{width:0%;}30%{width:22%;}60%{width:55%;}85%{width:78%;}100%{width:100%;}}
.loader-text{color:#555;font-size:11px;letter-spacing:3px;margin-top:14px;text-transform:uppercase;animation:fadeText 1.5s infinite alternate;}
@keyframes fadeText{0%{opacity:0.3;}100%{opacity:1;}}
body.loaded .loader-wrap{opacity:0;pointer-events:none;}
body.loaded .main-content{opacity:1;transform:translateY(0);}
.main-content{opacity:0;transform:translateY(18px);transition:opacity 0.8s ease,transform 0.8s ease;}
body.loaded .main-content{opacity:1;transform:translateY(0);}
::-webkit-scrollbar{width:7px;}
::-webkit-scrollbar-track{background:#111;}
::-webkit-scrollbar-thumb{background:#333;border-radius:3px;}
::-webkit-scrollbar-thumb:hover{background:#555;}
.header{display:flex;justify-content:space-between;align-items:center;padding:10px 20px;background:#0d0d0d;border-bottom:1px solid #1a1a1a;position:sticky;top:0;z-index:100;}
.logo{font-size:18px;font-weight:700;color:#fff;letter-spacing:2px;display:flex;align-items:center;gap:6px;}
.logo span{color:#666;font-weight:300;font-size:12px;letter-spacing:1px;}
.header-right{display:flex;align-items:center;gap:10px;}
.search-box{display:flex;align-items:center;background:#1a1a1a;border:1px solid #2a2a2a;border-radius:4px;padding:5px 12px;gap:6px;}
.search-box input{background:transparent;border:none;color:#ccc;outline:none;font-size:12px;width:130px;}
.search-box input::placeholder{color:#555;}
.search-box svg{color:#555;width:14px;height:14px;cursor:pointer;}
.search-box svg:hover{color:#fff;}
.demo-voice-btn{background:transparent;color:#aaa;border:1px solid #333;border-radius:4px;padding:5px 14px;font-size:11px;font-weight:500;cursor:pointer;display:flex;align-items:center;gap:5px;transition:0.2s;letter-spacing:0.5px;}
.demo-voice-btn:hover{border-color:#666;color:#fff;background:#1a1a1a;}
.demo-voice-btn.playing{border-color:#666;color:#fff;background:#1a1a1a;animation:pulseBorder 1s infinite;}
@keyframes pulseBorder{0%{border-color:#333;}50%{border-color:#666;}100%{border-color:#333;}}
.demo-voice-btn svg{width:13px;height:13px;}
.categories{display:flex;gap:2px;padding:8px 20px;background:#0d0d0d;border-bottom:1px solid #1a1a1a;overflow-x:auto;}
.categories::-webkit-scrollbar{display:none;}
.cat{background:transparent;color:#666;border:none;padding:5px 14px;font-size:11px;cursor:pointer;white-space:nowrap;transition:0.15s;letter-spacing:0.3px;border-radius:2px;}
.cat:hover{color:#ccc;background:#1a1a1a;}
.cat.active{color:#fff;background:#222;}
.container{max-width:1400px;margin:0 auto;padding:16px 20px;}
.section-title{font-size:15px;font-weight:600;color:#ddd;margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid #1a1a1a;letter-spacing:0.5px;text-transform:uppercase;}
.grid-3{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:12px;margin-bottom:36px;}
.video-card{background:#111;border:1px solid #1a1a1a;cursor:pointer;transition:0.2s;position:relative;}
.video-card:hover{border-color:#333;}
.thumb-wrap{position:relative;width:100%;padding-top:56.25%;background:#000;overflow:hidden;}
.thumb-wrap video{position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;}
.duration{position:absolute;bottom:6px;right:6px;background:rgba(0,0,0,0.85);color:#ccc;font-size:10px;padding:1px 6px;font-weight:500;letter-spacing:0.3px;}
.views{position:absolute;bottom:6px;left:6px;background:rgba(0,0,0,0.85);color:#ccc;font-size:10px;padding:1px 6px;display:flex;align-items:center;gap:3px;letter-spacing:0.3px;}
.views svg{width:10px;height:10px;}
.overlay{position:absolute;top:0;left:0;width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.4);opacity:0;transition:0.2s;}
.video-card:hover .overlay{opacity:1;}
.play-big{width:44px;height:44px;border:2px solid rgba(255,255,255,0.8);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;color:#fff;transition:0.2s;}
.video-card:hover .play-big{background:rgba(255,255,255,0.1);}
.video-info{padding:8px 10px 10px;}
.video-info h3{font-size:12px;font-weight:500;color:#ccc;margin-bottom:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;letter-spacing:0.2px;}
.video-info .meta{display:flex;gap:10px;font-size:10px;color:#555;}
.video-info .meta span{display:flex;align-items:center;gap:3px;}
.video-info .tag{display:inline-block;background:#1a1a1a;color:#777;font-size:9px;padding:1px 7px;margin-top:4px;letter-spacing:0.3px;}
.mummy-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:36px;}
.mummy-card{background:#111;border:1px solid #1a1a1a;padding:20px 16px;text-align:center;transition:0.2s;cursor:pointer;}
.mummy-card:hover{border-color:#444;}
.mummy-card .initial{width:64px;height:64px;border-radius:50%;background:#1a1a1a;border:2px solid #333;display:flex;align-items:center;justify-content:center;margin:0 auto 10px;font-size:20px;font-weight:700;color:#fff;transition:0.2s;}
.mummy-card:hover .initial{border-color:#666;background:#222;}
.mummy-card h3{font-size:15px;font-weight:600;color:#ddd;margin-bottom:2px;letter-spacing:0.3px;}
.mummy-card .tg-user{color:#666;font-size:11px;margin-bottom:8px;letter-spacing:0.3px;}
.mummy-card .tg-user span{color:#888;}
.mummy-card .sell-btn{background:transparent;color:#ccc;border:1px solid #333;padding:7px 20px;font-size:11px;font-weight:500;cursor:pointer;transition:0.2s;width:100%;letter-spacing:0.5px;margin-top:4px;}
.mummy-card .sell-btn:hover{border-color:#666;color:#fff;background:#1a1a1a;}
.banner-ad{background:#111;border:1px solid #1f1f1f;padding:20px 24px;margin-bottom:36px;display:flex;justify-content:space-between;align-items:center;}
.banner-ad h2{font-size:17px;font-weight:600;color:#ddd;letter-spacing:0.5px;}
.banner-ad p{color:#666;font-size:12px;margin-top:3px;letter-spacing:0.3px;}
.banner-ad .btn-ad{background:transparent;color:#ccc;border:1px solid #333;padding:8px 24px;font-weight:500;font-size:12px;cursor:pointer;transition:0.2s;letter-spacing:0.5px;}
.banner-ad .btn-ad:hover{border-color:#666;color:#fff;background:#1a1a1a;}
.channel-strip{display:flex;gap:12px;overflow-x:auto;margin-bottom:36px;padding-bottom:6px;}
.channel-strip::-webkit-scrollbar{height:3px;}
.channel-strip::-webkit-scrollbar-thumb{background:#333;border-radius:3px;}
.channel{min-width:120px;text-align:center;cursor:pointer;}
.channel .avatar{width:56px;height:56px;border-radius:50%;background:#1a1a1a;border:2px solid #222;display:flex;align-items:center;justify-content:center;margin:0 auto 6px;font-size:15px;font-weight:600;color:#888;transition:0.2s;}
.channel:hover .avatar{border-color:#444;color:#ccc;}
.channel .name{font-size:11px;font-weight:500;color:#aaa;}
.channel .subs{font-size:9px;color:#555;margin-top:1px;}
.tags-section{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:36px;}
.tag-item{background:#111;color:#666;border:1px solid #1a1a1a;padding:4px 12px;font-size:10px;text-decoration:none;transition:0.15s;letter-spacing:0.3px;}
.tag-item:hover{color:#ccc;border-color:#333;}
.pricing-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:12px;margin-bottom:36px;}
.price-card{background:#111;border:1px solid #1a1a1a;padding:22px 18px;text-align:center;}
.price-card.featured{border-color:#333;}
.price-card .price-icon{font-size:28px;margin-bottom:6px;color:#555;}
.price-card h3{font-size:14px;font-weight:600;color:#ddd;margin-bottom:4px;}
.price-card .price{font-size:26px;font-weight:700;color:#fff;margin:6px 0;letter-spacing:1px;}
.price-card .price-desc{color:#555;font-size:11px;margin-bottom:14px;}
.price-card .buy-btn{background:transparent;color:#ccc;border:1px solid #333;padding:8px 24px;font-weight:500;font-size:12px;cursor:pointer;transition:0.2s;width:100%;letter-spacing:0.5px;}
.price-card .buy-btn:hover{border-color:#666;color:#fff;background:#1a1a1a;}
.price-card.featured .buy-btn{border-color:#555;}
.footer{background:#0d0d0d;padding:28px 20px 18px;border-top:1px solid #1a1a1a;}
.footer-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:20px;max-width:1400px;margin:0 auto;}
.footer-col h4{font-size:12px;font-weight:600;color:#888;margin-bottom:10px;text-transform:uppercase;letter-spacing:1px;}
.footer-col a{display:block;color:#555;text-decoration:none;font-size:11px;margin-bottom:5px;transition:0.1s;}
.footer-col a:hover{color:#aaa;}
.footer-bottom{max-width:1400px;margin:16px auto 0;padding-top:12px;border-top:1px solid #1a1a1a;display:flex;justify-content:space-between;color:#444;font-size:10px;letter-spacing:0.3px;}
.modal{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.93);display:none;align-items:center;justify-content:center;z-index:1000;}
.modal.active{display:flex;}
.modal-content{position:relative;width:92%;max-width:780px;background:#000;border:1px solid #1a1a1a;}
.modal-content video{width:100%;display:block;max-height:80vh;}
.modal-close{position:absolute;top:-12px;right:-12px;width:30px;height:30px;background:#111;color:#888;border:1px solid #333;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:13px;transition:0.15s;z-index:10;}
.modal-close:hover{color:#fff;border-color:#666;}
.modal-info{padding:12px 16px;background:#0d0d0d;border-top:1px solid #1a1a1a;}
.modal-info h3{font-size:14px;font-weight:500;color:#ccc;}
.modal-info .meta{font-size:11px;color:#555;margin-top:2px;}
.voice-modal{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.9);display:none;align-items:center;justify-content:center;z-index:2000;}
.voice-modal.active{display:flex;}
.voice-content{background:#111;padding:28px 24px;text-align:center;max-width:360px;width:90%;border:1px solid #222;}
.voice-content .voice-icon{font-size:36px;margin-bottom:8px;color:#555;display:block;}
.voice-content h3{font-size:16px;font-weight:600;color:#ccc;margin-bottom:4px;letter-spacing:0.5px;}
.voice-content p{color:#555;font-size:12px;margin-bottom:16px;letter-spacing:0.3px;}
.voice-content .audio-player{width:100%;margin:8px 0 16px;}
.voice-content .audio-player audio{width:100%;}
.voice-content .voice-close{background:transparent;color:#aaa;border:1px solid #333;padding:8px 32px;font-weight:500;font-size:12px;cursor:pointer;transition:0.2s;letter-spacing:0.5px;}
.voice-content .voice-close:hover{border-color:#666;color:#fff;}
@media(max-width:768px){
.header{flex-wrap:wrap;gap:8px;}
.search-box input{width:90px;}
.grid-3{grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:8px;}
.mummy-grid{grid-template-columns:1fr;gap:10px;}
.pricing-grid{grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:8px;}
.banner-ad{flex-direction:column;text-align:center;gap:12px;padding:16px;}
.logo{font-size:15px;}
.footer-grid{grid-template-columns:repeat(2,1fr);}
.footer-bottom{flex-direction:column;gap:4px;text-align:center;}
}
</style>
</head>
